{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Resolve Worker Result",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "outcome": {
      "type": "string",
      "enum": [
        "resolved_job",
        "expanded",
        "skip_result",
        "result_failed"
      ]
    },
    "job": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "raw_url": {
          "type": "string",
          "minLength": 1
        },
        "canonical_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "company": {
          "type": [
            "string",
            "null"
          ]
        },
        "location": {
          "type": [
            "string",
            "null"
          ]
        },
        "posted_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "page_url": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "raw_url",
        "canonical_url",
        "source",
        "title",
        "company",
        "location",
        "posted_at",
        "page_url"
      ]
    },
    "child_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "snippet": {
            "type": [
              "string",
              "null"
            ]
          },
          "visible_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "page_number": {
            "type": "integer"
          },
          "rank": {
            "type": "integer"
          }
        },
        "required": [
          "url",
          "title",
          "snippet",
          "visible_date",
          "page_number",
          "rank"
        ]
      }
    },
    "skip_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "error_message": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "outcome",
    "job",
    "child_results",
    "skip_reason",
    "error_message"
  ]
}
