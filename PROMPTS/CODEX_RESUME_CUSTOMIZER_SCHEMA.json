{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Resume Customizer Result",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "bullet_blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "slug": {
            "type": "string",
            "minLength": 1
          },
          "bullets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "slug",
          "bullets"
        ]
      }
    }
  },
  "required": [
    "summary",
    "skills",
    "bullet_blocks"
  ]
}
