{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Query Worker Result",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "outcome": {
      "type": "string",
      "enum": [
        "candidate",
        "skip_result",
        "exhausted",
        "query_failed"
      ]
    },
    "candidate": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "raw_url": {
          "type": "string",
          "minLength": 1
        },
        "canonical_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "company": {
          "type": [
            "string",
            "null"
          ]
        },
        "location": {
          "type": [
            "string",
            "null"
          ]
        },
        "posted_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "page_url": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "raw_url",
        "canonical_url",
        "source",
        "title",
        "company",
        "location",
        "posted_at",
        "page_url"
      ]
    },
    "result_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "skip_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "error_message": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "outcome",
    "candidate",
    "result_url",
    "skip_reason",
    "error_message"
  ]
}
