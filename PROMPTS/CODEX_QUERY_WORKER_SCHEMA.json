{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Query Worker Result",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "outcome": {
      "type": "string",
      "enum": [
        "results_page",
        "exhausted",
        "query_failed"
      ]
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "snippet": {
            "type": [
              "string",
              "null"
            ]
          },
          "visible_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "page_number": {
            "type": "integer"
          },
          "rank": {
            "type": "integer"
          }
        },
        "required": [
          "url",
          "title",
          "snippet",
          "visible_date",
          "page_number",
          "rank"
        ]
      }
    },
    "next_page": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "page_number": {
          "type": "integer"
        }
      },
      "required": [
        "page_number"
      ]
    },
    "query_error": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "outcome",
    "results",
    "next_page",
    "query_error"
  ]
}
